# Entornos Virtuales
.venv/
venv/
env/
.env

# Caché y artefactos de Python
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/

# Jupyter Notebooks
.ipynb_checkpoints/

# Directorio de Datos (NO SUBIR DATOS A GIT POR DEFECTO)
