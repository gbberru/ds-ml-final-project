#data/interim/
#data/processed/
#data/external/

# Mantener la estructura de carpetas de datos aunque estén vacías
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Modelos
#models/
!models/.gitkeep

